{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // composite 项目必须可发射;只生成声明文件到独立目录(不污染源码)。
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.tmp/tsconfig.node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
