# ── DApp 运行所需的环境变量 ───────────────────────────────
# 复制本文件为 .env 即可直接连到下面这个【已部署在 Sepolia 的真实合约】跑通。
# 只有以 VITE_ 开头的变量会注入前端。

# 目标链 ID(十进制)。Sepolia = 11155111;主网 = 1。
VITE_CHAIN_ID=11155111

# RPC URL。下面是可用的公共 Sepolia RPC(会限流);正式用请换 Alchemy/Infura 的 key。
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# 🟢 已部署在 Sepolia 的 StudioToken(ERC-20),Sourcify 已验证源码。
# 直接连这个就能读余额 / 发交易演示;想换成自己的就改这里。
VITE_TOKEN_ADDRESS=0x834a5cE3a7b214369DbaFcc59757031c259C3984
