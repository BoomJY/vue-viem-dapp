# ── DApp 运行所需的环境变量(物理条件) ───────────────────────────────
# 复制本文件为 .env 后按需填写。只有以 VITE_ 开头的变量会注入前端。
#
# 不填任何变量也能跑:默认目标链为 Sepolia,使用公共 RPC,
# 代币区域会提示去填合约地址。

# 目标链 ID(十进制)。Sepolia = 11155111;主网 = 1。
VITE_CHAIN_ID=11155111

# 自定义 RPC URL(可选,强烈建议)。
# 公共 RPC 会限流,正式使用请去 Alchemy / Infura 申请一个:
#   Alchemy: https://www.alchemy.com/
#   Infura : https://www.infura.io/
# 例如:https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>
VITE_RPC_URL=

# 你部署/使用的 ERC-20 合约地址(0x 开头,40 位十六进制)。
# 没有的话,可以用本仓库系列中的 02-foundry-erc20-token 部署一个,
# 或在 Sepolia 上找任意带公开 mint 的测试代币。
VITE_TOKEN_ADDRESS=
